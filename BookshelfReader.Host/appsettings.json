{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "localhost;127.0.0.1",
  "Authentication": {
    "ApiKey": {
      "HeaderName": "X-API-Key",
      "RequireApiKey": false,
      "ValidKeys": []
    }
  },
  "OpenLibrary": {
    "BaseUrl": "https://openlibrary.org/"
  },
  "Enrichment": {
    "Enabled": true,
    "MaxConcurrentLookups": 4,
    "MinMatchScore": 55
  },
  "RateLimiting": {
    "Parse": {
      "Enabled": true,
      "PermitLimit": 10,
      "WindowSeconds": 60,
      "QueueLimit": 0
    }
  },
  "Uploads": {
    "MaxBytes": 10485760,
    "AllowedContentTypes": [
      "image/jpeg",
      "image/png"
    ],
    "MaxImagePixels": 25000000
  },
  "ClaudeVision": {}
}
